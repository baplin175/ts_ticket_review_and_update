# ── Azure AD App Registration ────────────────────────────────────────
# Create an app at https://portal.azure.com → Azure Active Directory →
# App registrations.  Add the redirect URI "https://login.microsoftonline.com/common/oauth2/nativeclient"
# for device-code flow.

GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=

# ── Optional ─────────────────────────────────────────────────────────
# Override where the serialized token cache is stored.
# Defaults to .token_cache.bin in this folder.
# GRAPH_TOKEN_CACHE_PATH=
